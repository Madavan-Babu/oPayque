<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260131-003-add-description" author="madavan">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="ledger_entries"/>
            <not>
                <columnExists tableName="ledger_entries" columnName="description"/>
            </not>
        </preConditions>

        <comment>Fixing Schema: Adding missing description column</comment>

        <addColumn tableName="ledger_entries">
            <column name="description" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>