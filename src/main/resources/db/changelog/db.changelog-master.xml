<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20240520-001-create-users-table" author="madavan">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="users"/>
            </not>
        </preConditions>
        <createTable tableName="users">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="full_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="deleted_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <include file="db/changelog/changes/002-create-refresh-tokens.xml" relativeToChangelogFile="false"/>
    <include file="db/changelog/changes/003-create-accounts-ledger.xml" relativeToChangelogFile="false"/>
    <include file="db/changelog/changes/004-add-iban-to-accounts.xml" relativeToChangelogFile="false"/>
    <include file="db/changelog/changes/005-create-account-sequence.xml" relativeToChangelogFile="false"/>
    <include file="db/changelog/changes/006-alter-ledger-add-exchange-metadata.xml" relativeToChangelogFile="false"/>
    <include file="db/changelog/changes/007-add-missing-ledger-columns.xml" relativeToChangelogFile="false"/>
    <include file="db/changelog/changes/008-add-description.xml" relativeToChangelogFile="false"/>
    <include file="db/changelog/changes/009-add-covering-index.xml" relativeToChangelogFile="false"/>
    <include file="db/changelog/changes/010-add-reference-id.xml" relativeToChangelogFile="false"/>
    <include file="db/changelog/changes/011-create-virtual-cards.xml" relativeToChangelogFile="false"/>
    <include file="db/changelog/changes/012-harden-card-schema.xml" relativeToChangelogFile="false"/>
    <include file="db/changelog/changes/013-add-optimistic-locking.xml" relativeToChangelogFile="false"/>
    <include file="db/changelog/changes/014-add-account-status.xml" relativeToChangelogFile="false"/>

</databaseChangeLog>